// test_with_deps.yak
// Test loop_write_python_script with third-party dependencies
// Verifies: write_script, check_and_install_dependencies, auto_execute_script
//
// Assertions:
// 1. Must successfully get script file path
// 2. Script must contain third-party import (requests)
// 3. Script must contain argparse CLI entry point
// 4. Script content length must be > 100 bytes
//
// Run: go run common/yak/cmd/yak.go common/ai/aid/aireact/reactloops/loop_write_python_script/examples/test_with_deps.yak

var scriptFilename = ""
var scriptContent = ""
var executionError = nil

testPrompt = `Please generate a Python script that implements a simple HTTP health checker.

Requirements:
1. Use the 'requests' library to send HTTP GET requests
2. Accept one or more URLs as command-line arguments
3. Check each URL and report status code and response time
4. Use argparse for CLI entry point
5. Handle connection errors gracefully
6. Keep it simple and focused, this is a test.`

log.Info("========================================")
log.Info("Testing loop_write_python_script - With Dependencies")
log.Info("========================================")

err = aim.InvokeReAct(
    testPrompt,
    aim.focus("write_python_script"),
    aim.aiConfig("aibalance", ai.model("deepseek-v3.2")),
    aim.timeout(420),
    aim.maxIteration(25),
    aim.onEvent(func(react, event) {
        eventType = string(event.Type)

        if eventType == "filesystem_pin_filename" {
            contentStr = string(event.Content)
            if len(contentStr) > 0 {
                try {
                    jsonData = json.loads(contentStr)
                    if jsonData != nil && jsonData["path"] != nil {
                        path = string(jsonData["path"])
                        if str.HasSuffix(path, ".py") {
                            scriptFilename = path
                        }
                    }
                } catch e {
                    // ignore
                }
            }
        }
    }),
    aim.onFinished(func(react) {
        if scriptFilename != "" {
            content, readErr = file.ReadFile(scriptFilename)
            if readErr == nil {
                scriptContent = string(content)
            }
        }
    }),
)

if err != nil {
    executionError = err
}

// ========================================
// Assertions
// ========================================

log.Info("========================================")
log.Info("RUNNING ASSERTIONS")
log.Info("========================================")

assert executionError == nil, sprintf("ReAct execution failed: %v", executionError)

assert scriptFilename != "", "Failed to capture script filename from events"

assert file.IsExisted(scriptFilename), sprintf("Script file does not exist: %s", scriptFilename)

contentLen = len(scriptContent)
assert contentLen > 100, sprintf("Script content too short. Expected > 100 bytes, got %d bytes", contentLen)

hasRequests = str.Contains(scriptContent, "requests")
assert hasRequests, sprintf("Script should use the requests library. Content preview: %s", scriptContent[:min(len(scriptContent), 300)])

hasArgparse = str.Contains(scriptContent, "argparse")
assert hasArgparse, sprintf("Script must use argparse for CLI entry point. Content preview: %s", scriptContent[:min(len(scriptContent), 300)])

hasMainGuard = str.Contains(scriptContent, "__main__")
assert hasMainGuard, sprintf("Script must have if __name__ == '__main__' guard. Content preview: %s", scriptContent[:min(len(scriptContent), 300)])

log.Info("========================================")
log.Info("ALL ASSERTIONS PASSED!")
log.Info("========================================")
log.Info("Script Filename: %s", scriptFilename)
log.Info("Script Content Length: %d bytes", contentLen)
log.Info("Full Script:\n%s", scriptContent)
