        "display": "Spring Boot / Spring MVC",
        "arch_tool": "java_audit/spring_boot_arch_info",
        "config_tool": "java_audit/spring_boot_config_audit",
        "file_markers": ["pom.xml", "build.gradle", "application.properties", "application.yml", "application.yaml"],
        "content_markers": ["@SpringBootApplication", "org.springframework.boot", "spring-boot-starter"],
        "strong_content_markers": ["@SpringBootApplication", "spring-boot-starter", "org.springframework.boot"],
    },
    {
        "name": "servlet",
        "display": "Servlet / Java EE",
        "arch_tool": "java_audit/servlet_arch_info",
        "config_tool": "java_audit/servlet_config_audit",
        "file_markers": ["web.xml", "WEB-INF"],
        "content_markers": ["javax.servlet", "jakarta.servlet", "<servlet", "<filter"],
