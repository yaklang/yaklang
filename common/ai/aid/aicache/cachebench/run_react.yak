// aicache cache hit benchmark - run_react.yak
//
// 用 aim.InvokeReAct 真实驱动一次 ReAct 闭环, 同时通过 ai.usageCallback
// 抓上游 LLM 在 SSE 末帧返回的 token 用量 (含 cached_tokens / cache_creation_input_tokens),
// 配合 aicache 自动落盘的 dump 文件, 输出"客户端 LCP 命中" + "上游真实命中"双路对齐报告。
//
// 默认 input 改为可自动触发 loop_plan -> pe-task 链路的渗透测试目标,
// 旧的 "hostscan" 单 forge 入口命中率已被优化到很高, 不能反映 plan / pe-task
// 二段流水线的真实缓存表现. 新默认会先进入普通模式判定意图, 自动启动 loop_plan
// 收集 facts, 再生成执行计划进入 pe-task 子任务执行, 是当前缓存命中瓶颈的主路径.
//
// 用法 (必须从 yaklang 仓库根目录运行, 因为 include 走 cwd 相对路径):
//   cd /path/to/yaklang
//   go run common/yak/cmd/yak.go \
//       common/ai/aid/aicache/cachebench/run_react.yak \
//       --ai-type aibalance --max-iteration 20
//   # 想换 input 直接传 --input "..." 覆盖默认
//
// 关键词: aicache cachebench, run_react, usageCallback, dump alignment,
//         loop_plan, pe-task, plan-execution chain benchmark

// include 路径相对当前工作目录 (yak 编译器行为), 因此约定必须从仓库根目录调用。
include "common/ai/aid/aicache/cachebench/lib.yak"

// =============================================================================
// 启用 aicache dump 落盘
// 关键词: cachebench enable dump, YAKLANGDEBUG
// =============================================================================
// aicache.dumpDebug 仅在 utils.InDebugMode() 触发, 这里强制打开 YAKLANGDEBUG。
// 必须在调用 aim.InvokeReAct 之前设置, 否则首条 prompt 不会落盘。
os.Setenv("YAKLANGDEBUG", "1")

// =============================================================================
// CLI 参数
// =============================================================================
// 关键词: cachebench default input, loop_plan + pe-task 触发, 渗透测试 18080
// 默认 input 是一个能触发普通模式 -> loop_plan -> pe-task 全链路的渗透测试请求,
// 命中当前 cache miss 主战场 (PE Task 子任务跨 turn 的 reactive_data / facts /
// document 在 dynamic 段每轮 nonce 漂移). 旧默认 "hostscan" 走单 forge 路径,
// 命中率已经压到极高, 反而无法暴露 plan-exec 链上的命中率塌陷.
inputText  = cli.String("input", cli.setDefault("渗透测试，http://127.0.0.1:18080"),
    cli.setHelp("传给 aim.InvokeReAct 的初始 user input, 默认会触发 loop_plan + pe-task 链路"))
aiType     = cli.String("ai-type", cli.setDefault("aibalance"),
    cli.setHelp("aim.aiConfig 的第一个参数, 选 aispec 注册的 provider 名 (aibalance/openai/...)"))
aiModel    = cli.String("ai-model", cli.setDefault(""),
    cli.setHelp("可选, 强制覆盖 chater 默认 model (aibalance 多模型路由建议留空)"))
timeoutSec = cli.Int("timeout", cli.setDefault(60*20),
    cli.setHelp("aim.InvokeReAct 与单次 LLM 调用超时, 默认 1200 秒"))
maxIter    = cli.Int("max-iteration", cli.setDefault(15),
    cli.setHelp("React 循环最大迭代次数"))
maxPrompts = cli.Int("max-prompts", cli.setDefault(0),
    cli.setHelp("收集到 N 次 LLM prompt usage 后立即 cancel context 提前退出 (0 = 不限制)"))
maxDuration = cli.Int("max-duration", cli.setDefault(0),
    cli.setHelp("benchmark hard cap in seconds, 0 = unlimited; cancel ctx after duration, 与 max-prompts 互不干扰"))
language   = cli.String("language", cli.setDefault("zh"),
    cli.setHelp("传给 aim.language 的语言, 默认中文"))
outputDir  = cli.String("output-dir",
    cli.setDefault("./common/ai/aid/aicache/cachebench/reports"),
    cli.setHelp("报告产物根目录, 内部会自动建立 bottleneck-prompts 子目录"))
// 关键词: cachebench session isolation, persistent timeline pollution, default session
// 不传或留空 = 用 cachebench-<unix-ts>-<pid> 形式自动隔离, 避免和默认 session 共享 timeline
// 标准客户端每次会话都会建独立 sessionID, 不会污染. cachebench 历史用过 default,
// 一旦累积上千条 timeline 条目, 每次 subtask 切换 / React loop init 都会
// reload + reassign 所有条目, 造成多分钟"卡顿"假象 (见 P3-X2 排障).
sessionID = cli.String("session-id", cli.setDefault(""),
    cli.setHelp("传给 aim.sessionID 的会话 ID, 留空 = 自动生成独立 cachebench session 避免污染默认 session"))

// =============================================================================
// 失速 / 限流 / 错误的"立即退出"开关 (P3-A1: fast-fail switches)
// 关键词: cachebench fast fail, stall watchdog, rate limit abort, error abort
// =============================================================================
// stall-timeout: 多少秒内没有新 usage 回调到达就视为卡死, 主动取消 ctx 并保存部分报告
stallTimeout = cli.Int("stall-timeout", cli.setDefault(120),
    cli.setHelp("无新 usage 回调达 N 秒视为失速, 立即取消并保存部分报告 (0 = 不启用)"))
// max-throttle-events: 上游 429 / rate-limit 类提示累计达到 N 次就主动退出, 防止"假装在跑"
maxThrottleEvents = cli.Int("max-throttle-events", cli.setDefault(3),
    cli.setHelp("上游 429 / rate-limit 类事件累计 >= N 次后立即退出 (0 = 不启用)"))
// abort-on-fatal-error: 收到 max retry / 401 / 严重 error 事件立刻退出
abortOnFatalError = cli.Bool("abort-on-fatal-error",
    cli.setHelp("命中 max retry / 401 / Unauthorized / fail_react_task 等致命事件立即退出 (默认开)"))
cli.check()

// 自动生成独立 session 防止默认 session timeline 污染
// 关键词: cachebench session-id auto, persistent timeline isolation
if sessionID == "" {
    sessionID = sprintf("cachebench-%d-%d", time.Now().Unix(), os.Getpid())
}

log.info("aicache cachebench - input=%s ai-type=%s session-id=%s max-iteration=%d max-prompts=%d max-duration=%ds stall-timeout=%ds max-throttle-events=%d abort-on-fatal-error=%v",
    inputText, aiType, sessionID, maxIter, maxPrompts, maxDuration, stallTimeout, maxThrottleEvents, abortOnFatalError)

// =============================================================================
// 取消上下文 (用于 max-prompts 限流 / max-duration 时间硬截断)
// =============================================================================
// 当 maxPrompts > 0, 在 captureUsage 第 N 次回调时 cancel 这个 ctx;
// 当 maxDuration > 0, 后台 goroutine 在 N 秒后 cancel 这个 ctx;
// 两条路径互不干扰, 谁先到谁触发, 第二个触发时 cancel 已是 no-op.
// aim.InvokeReAct 收到 ctx.Done() 会停掉 React loop 并返回 context canceled.
// 关键词: cachebench max-prompts, max-duration, ctx cancel
benchCtx, benchCancel = context.WithCancel(context.Background())
defer benchCancel()
maxPromptsTriggered = false
maxDurationTriggered = false
stallTriggered      = false
throttleTriggered   = false
fatalErrorTriggered = false

// 抢占式触发原因记录, 第一个 set 的胜出, 后续无视 (避免覆盖). 用 mutex 保护一致性.
// 关键词: cachebench abortReason, first-trigger-wins
triggerMu     = sync.NewMutex()
abortReason   = ""           // 文字形式 abort 原因, 留空 = 正常完成
abortDetail   = ""           // 详细信息 (具体事件内容 / 命中关键词)
abortAtSec    = 0            // 触发时距离启动的秒数

func setAbortReason(reason, detail) {
    triggerMu.Lock()
    defer triggerMu.Unlock()
    if abortReason != "" {
        return
    }
    abortReason = reason
    abortDetail = detail
    abortAtSec = time.Now().Unix() - invokeStartUnix
    log.warn("ABORT trigger fired: reason=%s detail=%s at +%ds", reason, detail, abortAtSec)
    benchCancel()
}

// invokeStartUnix 在 InvokeReAct 调用前赋值, 但 captureEvent / 后台 goroutine 可能在它赋值
// 之前就引用. 给一个安全的初值, 防 setAbortReason 在那之前触发时取负.
// 关键词: cachebench invokeStartUnix init
invokeStartUnix = time.Now().Unix()

// 后台计时器: maxDuration 秒后强制取消 ctx
// 关键词: cachebench max-duration trigger, hard cap
if maxDuration > 0 {
    go func {
        time.sleep(maxDuration)
        if !maxPromptsTriggered {
            maxDurationTriggered = true
            setAbortReason("max-duration", sprintf("%ds hard cap reached", maxDuration))
        }
    }
}

// =============================================================================
// usage 收集器
// =============================================================================
// aim.aiConfig 把 ai.usageCallback 透传到 aispec.ChatBase, 在 SSE 末帧解析后调用。
// React loop 里 chat 是顺序执行的, 因此这里按调用次序累加, 与 aicache 落盘的
// 000XXX.txt 文件序号一一对应。
//
// 关键词: cachebench usageCallback, 顺序对齐
usageMu     = sync.NewMutex()
usageList   = []
usageCount  = 0
firstUsage  = nil
// usageWithIDCount / usageNoIDCount 统计 SSE 末帧 usage 是否带 MirrorCorrelationID.
// 部署完整链路 (新 yak binary + 新 aicache) 后, withID 应当 ~= usageCount, noID ~= 0.
// 若 noID > 0, 说明跑的还是旧 binary 或途中走了不带 mirror 的 ChatBase 通路.
// 关键词: cachebench correlationID stats, ID 部署可观测
usageWithIDCount = 0
usageNoIDCount   = 0

// 后台失速看门狗: 必须放在 usageList 声明之后, 否则 goroutine 闭包捕获不到变量.
// 每 5 秒检查一次, 若 usage 回调数量在 stallTimeout 秒内没有任何增长,
// 视为底层卡死 (上游不响应 / network hang / aibalance 内部死循环), 主动退出并保存部分报告.
// 关键词: cachebench stall watchdog, no-progress detector
if stallTimeout > 0 {
    go func {
        prevCount = 0
        prevTs    = time.Now().Unix()
        for true {
            time.sleep(5)
            if abortReason != "" {
                return
            }
            cur = len(usageList)
            now = time.Now().Unix()
            if cur > prevCount {
                prevCount = cur
                prevTs    = now
                continue
            }
            // 没增长: 看是否超过 stallTimeout 秒
            // 注意: 当 cur == 0 时也启动看门狗, 避免完全没出第一个回调时永远卡住
            elapsed = now - prevTs
            if elapsed >= stallTimeout {
                stallTriggered = true
                setAbortReason("stall",
                    sprintf("no new usage callback in %ds (last count=%d)", elapsed, cur))
                return
            }
        }
    }
}

func captureUsage(usage) {
    usageMu.Lock()
    defer usageMu.Unlock()
    usageCount++
    if usage == nil {
        // 区分两种 nil callback:
        //   1) max-prompts 触发后到达的 nil = 测量伪影 (ctx cancel 中断 SSE 末帧),
        //      不计入 missing 链路诊断
        //   2) max-prompts 触发前的 nil = 真实"上游没回 usage 或 callback 链路漏接",
        //      需要 P1-D 类继续排查
        // 关键词: captureUsage in_flight_cancelled, missing usage 测量伪影
        cancelled = maxPromptsTriggered
        record = {
            "seq":     usageCount,
            "missing": !cancelled,
            "inFlightCancelled": cancelled,
            "ts":      time.Now().Unix(),
        }
        usageList = append(usageList, record)
        if cancelled {
            log.info("usage callback nil after max-prompts cancel (in-flight, expected): seq=%d", usageCount)
        } else {
            log.warn("usage callback fired with nil (provider did not return usage block): seq=%d", usageCount)
        }
        return
    }

    cached    = 0
    creation  = 0
    cacheType = ""
    textTok   = 0
    if usage.PromptTokensDetails != nil {
        cached    = usage.PromptTokensDetails.CachedTokens
        creation  = usage.PromptTokensDetails.CacheCreationInputTokens
        cacheType = usage.PromptTokensDetails.CacheType
        textTok   = usage.PromptTokensDetails.TextTokens
    }

    // correlationID 来自 ChatUsage.MirrorCorrelationID, 由 ChatBase 在
    // dispatchChatBaseMirror 后从 mirrorResult.MirrorCorrelationID 透传上来.
    // aicache.Observe 把当次 SeqId 字符串写到 mirrorResult, 所以这里的 ID 等于
    // 落盘 dump 的 000XXX.txt 文件名前缀, 让 lib.yak 的 alignDumpsAndUsages 按
    // ID 精确 join, 修掉中途漏 callback 引发的累计错位归因 bug.
    // 关键词: captureUsage MirrorCorrelationID, dump usage 精确 join
    correlationID = usage.MirrorCorrelationID

    record = {
        "seq":              usageCount,
        "missing":          false,
        "promptTokens":     usage.PromptTokens,
        "completionTokens": usage.CompletionTokens,
        "totalTokens":      usage.TotalTokens,
        "cachedTokens":     cached,
        "cacheCreation":    creation,
        "cacheType":        cacheType,
        "textTokens":       textTok,
        "ts":               time.Now().Unix(),
        "correlationID":    correlationID,
    }
    usageList = append(usageList, record)
    if correlationID != "" {
        usageWithIDCount++
    } else {
        usageNoIDCount++
    }

    if firstUsage == nil {
        firstUsage = record
        log.info("first usage callback received: prompt=%d cached=%d creation=%d correlationID=%s",
            usage.PromptTokens, cached, creation, correlationID)
    }

    // 限流: 收满 maxPrompts 次就 cancel context, 让 aim.InvokeReAct 优雅停止
    // 关键词: cachebench max-prompts trigger
    if maxPrompts > 0 && usageCount >= maxPrompts && !maxPromptsTriggered {
        maxPromptsTriggered = true
        log.info("max-prompts(%d) reached, cancelling context to stop React loop", maxPrompts)
        benchCancel()
    }
}

// =============================================================================
// 事件采集 (节流, 不阻塞)
// =============================================================================
events = []
maxEventsKept = 200

// modelList 记录每次 AI 调用的目标 model_name (来自 ai_first_byte_cost_ms 事件).
// React loop 中 chat 顺序触发, 一次 AI 请求会先 emit AI_FIRST_BYTE_COST_MS (含 model_name),
// 再调用 ai.usageCallback (captureUsage), 因此 modelList 与 usageList 按到达顺序一一对应.
// 上游路由的 model_tier (intelligent / lightweight) 也一并记录, 便于对比 standard / light tier.
// 关键词: cachebench modelList, ai_first_byte_cost_ms, model_tier, standard vs light
modelMu     = sync.NewMutex()
modelList   = []
modelEventCount = 0

// 限流 / 错误事件计数器, 供 fast-fail 触发使用.
// 关键词: cachebench throttleCount, fatalErrorCount
throttleEventCount = 0
fatalErrorCount    = 0
throttleSamples    = []  // 最近 5 条 throttle 命中预览, 给报告用
fatalSamples       = []  // 最近 5 条 fatal 命中预览, 给报告用

// detectThrottleHit: 若 content 命中 429 / rate-limit / queue 等关键词, 返回非空 reason
// 关键词: cachebench detectThrottleHit, 429, rate-limit, queue
func detectThrottleHit(eventType, contentText) {
    // aibalance 在 EmitDefaultStreamEvent 用 nodeName="rate-limit" / "notify"
    // 但 nodeName 不直接暴露, 改抓 content 文本特征. 命中任一即认为 throttle.
    if str.Contains(contentText, "rate_limit_exceeded") {
        return "rate_limit_exceeded payload"
    }
    if str.Contains(contentText, "队列位置") || str.Contains(contentText, "Rate limit exceeded") {
        return "rate-limit message"
    }
    if str.Contains(contentText, "HTTP 429") || str.Contains(contentText, "429 Too Many Requests") {
        return "HTTP 429"
    }
    if str.Contains(contentText, "AIBalance 429") {
        return "AIBalance 429"
    }
    if str.Contains(contentText, "rate-limited") {
        return "rate-limited"
    }
    if str.Contains(contentText, "稍后自动重试") && str.Contains(contentText, "429") {
        return "auto-retry on 429"
    }
    return ""
}

// detectFatalHit: 命中 max retry / 401 / fail_react_task 等致命模式
// 关键词: cachebench detectFatalHit, max retry count, 401, Unauthorized, fail_react_task
func detectFatalHit(eventType, contentText) {
    if eventType == "fail_react_task" {
        return "fail_react_task event"
    }
    if eventType == "fail_plan_and_execution" {
        return "fail_plan_and_execution event"
    }
    if str.Contains(contentText, "max retry count") && str.Contains(contentText, "reached") {
        return "max retry count reached"
    }
    if str.Contains(contentText, "401 Unauthorized") {
        return "HTTP 401"
    }
    if str.Contains(contentText, "Unauthorized") && str.Contains(contentText, "api_key") {
        return "auth failed"
    }
    if str.Contains(contentText, "context deadline exceeded") && str.Contains(contentText, "ChatBase") {
        return "ChatBase deadline"
    }
    return ""
}

func captureEvent(react, event) {
    eventType = string(event.Type)
    contentText = string(event.Content)

    // P3-A1: 限流 / 致命错误 fast-fail 检测
    // 关键词: captureEvent fast fail, throttle abort, fatal abort
    if maxThrottleEvents > 0 {
        throttleHit = detectThrottleHit(eventType, contentText)
        if throttleHit != "" {
            throttleEventCount++
            preview = ccbTruncate(contentText, 200)
            if len(throttleSamples) < 5 {
                throttleSamples = append(throttleSamples, sprintf("[%s] %s :: %s", eventType, throttleHit, preview))
            }
            log.warn("throttle event #%d: type=%s reason=%s preview=%s",
                throttleEventCount, eventType, throttleHit, preview)
            if throttleEventCount >= maxThrottleEvents {
                throttleTriggered = true
                setAbortReason("throttle",
                    sprintf("upstream throttle hit %d times (limit=%d), last=%s", throttleEventCount, maxThrottleEvents, throttleHit))
            }
        }
    }
    if abortOnFatalError {
        fatalHit = detectFatalHit(eventType, contentText)
        if fatalHit != "" {
            fatalErrorCount++
            preview = ccbTruncate(contentText, 200)
            if len(fatalSamples) < 5 {
                fatalSamples = append(fatalSamples, sprintf("[%s] %s :: %s", eventType, fatalHit, preview))
            }
            log.warn("fatal-error event #%d: type=%s reason=%s preview=%s",
                fatalErrorCount, eventType, fatalHit, preview)
            // fatal 事件只要命中一次就退出, 与 throttle 多次累计不同
            fatalErrorTriggered = true
            setAbortReason("fatal-error",
                sprintf("fatal pattern matched: %s (event=%s)", fatalHit, eventType))
        }
    }

    if eventType == "ai_first_byte_cost_ms" {
        modelMu.Lock()
        modelEventCount++
        seq = modelEventCount
        // content 是 JSON, 字段: model_name / provider_name / model_tier / ms / second
        // 关键词: ai_first_byte_cost_ms parse, model_name 提取
        modelName = ""
        modelTier = ""
        providerName = ""
        try {
            obj = json.loads(contentText)
            if obj != nil {
                modelName = ccbToString(obj["model_name"])
                modelTier = ccbToString(obj["model_tier"])
                providerName = ccbToString(obj["provider_name"])
            }
        } catch e {
            log.warn("captureEvent parse ai_first_byte_cost_ms failed: %v", e)
        }
        modelList = append(modelList, {
            "seq":          seq,
            "modelName":    modelName,
            "modelTier":    modelTier,
            "providerName": providerName,
            "ts":           time.Now().Unix(),
        })
        modelMu.Unlock()
    }
    if len(events) >= maxEventsKept {
        return
    }
    events = append(events, {
        "type":           eventType,
        "ts":             time.Now().Unix(),
        "contentPreview": ccbTruncate(contentText, 200),
    })
}

// =============================================================================
// 触发 aim.InvokeReAct
// =============================================================================
aiOpts = [ai.usageCallback(captureUsage), ai.timeout(timeoutSec)]
if aiModel != "" {
    aiOpts = append(aiOpts, ai.model(aiModel))
}

invokeStart = time.Now()
invokeStartUnix = invokeStart.Unix()
log.info("invoking aim.InvokeReAct, dump dir will be: %s", ai.aicacheSession())

err = aim.InvokeReAct(
    inputText,
    aim.context(benchCtx),
    aim.aiConfig(aiType, aiOpts...),
    aim.sessionID(sessionID),
    aim.timeout(timeoutSec),
    aim.maxIteration(maxIter),
    aim.language(language),
    aim.yoloMode(),
    aim.allowUserInteract(false),
    aim.onEvent(captureEvent),
)

invokeEnd = time.Now()
durationSec = invokeEnd.Unix() - invokeStart.Unix()

// abort 路径覆盖原来的 if/else 链, 任意 trigger 都视为预期退出, 不以 die() 收场.
// 关键词: cachebench abort summary, expected vs unexpected error
ctxCancelled = (abortReason != "") || maxPromptsTriggered || maxDurationTriggered

if err != nil {
    if abortReason != "" {
        log.info("aim.InvokeReAct stopped by [%s] after %d seconds (expected): detail=%s err=%v",
            abortReason, durationSec, abortDetail, err)
    } else if maxPromptsTriggered {
        log.info("aim.InvokeReAct stopped by max-prompts after %d seconds (expected): %v", durationSec, err)
    } else if maxDurationTriggered {
        log.info("aim.InvokeReAct stopped by max-duration after %d seconds (expected): %v", durationSec, err)
    } else {
        log.warn("aim.InvokeReAct returned error: %v", err)
    }
} else {
    log.info("aim.InvokeReAct completed in %d seconds", durationSec)
}

// =============================================================================
// 等待末帧到达, 避免 ReAct loop 自然结束时 last-iteration chat 的 SSE 末帧
// (token usage block) 还没到达就开始对齐, 导致最后 1-2 条 dump 被误判 missing.
// 关键词: cachebench tail_in_flight, SSE 末帧等待
// =============================================================================
prevUsageCount = -1
stableMs = 0
maxWaitMs = 3000
stepMs = 200
for stableMs < 1500 && maxWaitMs > 0 {
    time.sleep(stepMs / 1000.0)
    maxWaitMs -= stepMs
    cur = len(usageList)
    if cur == prevUsageCount {
        stableMs += stepMs
    } else {
        stableMs = 0
        prevUsageCount = cur
    }
}
log.info("post-react drain done, final usage count = %d, model events = %d", len(usageList), len(modelList))

// =============================================================================
// 拉取 aicache dump 目录, 做对齐分析
// =============================================================================
sessionDir = ai.aicacheSession()
log.info("analyzing dumps in: %s", sessionDir)
log.info("usage callbacks captured: %d", len(usageList))
log.info("usage with correlationID: %d, without correlationID: %d (旧 binary 或非 mirror 通路 = 0)",
    usageWithIDCount, usageNoIDCount)
log.info("model events captured: %d", len(modelList))

// 任何 ctx cancel 路径 (max-prompts / max-duration / stall / throttle / fatal) 触发的
// trailing dumps 都视为 in_flight_cancelled 测量伪影, 而不是 missing usage 漏接.
// 关键词: run_react ctxCancelled, trailing dumps 归类
benchReport = analyzeBenchmarkWithModels(sessionDir, usageList, modelList, events, err, inputText, ctxCancelled)
benchReport["durationSec"] = durationSec
benchReport["aiType"] = aiType
benchReport["aiModel"] = aiModel
benchReport["maxIteration"] = maxIter
benchReport["maxPrompts"] = maxPrompts
benchReport["maxPromptsTriggered"] = maxPromptsTriggered
benchReport["maxDuration"] = maxDuration
benchReport["maxDurationTriggered"] = maxDurationTriggered
// 抢占式 abort 元数据: 让报告读者一眼看清是否被强制退出 / 因什么退出
// 关键词: cachebench report abort metadata
benchReport["abortReason"] = abortReason
benchReport["abortDetail"] = abortDetail
benchReport["abortAtSec"]  = abortAtSec
benchReport["stallTimeout"] = stallTimeout
benchReport["stallTriggered"] = stallTriggered
benchReport["maxThrottleEvents"] = maxThrottleEvents
benchReport["throttleTriggered"] = throttleTriggered
benchReport["throttleEventCount"] = throttleEventCount
benchReport["throttleSamples"] = throttleSamples
benchReport["abortOnFatalError"] = abortOnFatalError
benchReport["fatalErrorTriggered"] = fatalErrorTriggered
benchReport["fatalErrorCount"] = fatalErrorCount
benchReport["fatalSamples"] = fatalSamples

jsonPath, mdPath, botDir = saveReport(outputDir, benchReport)

log.info("benchmark report saved:")
log.info("  json:               %s", jsonPath)
log.info("  markdown:           %s", mdPath)
log.info("  bottleneck-prompts: %s", botDir)
log.info("  session dump dir:   %s", sessionDir)

printSummary(benchReport)

// 输出 abort 总结到 stdout / log, 帮助快速定位
// 关键词: cachebench abort summary block, fast-fail visible
if abortReason != "" {
    log.warn("=========== ABORT SUMMARY ===========")
    log.warn("reason:          %s", abortReason)
    log.warn("detail:          %s", abortDetail)
    log.warn("at:              +%ds", abortAtSec)
    log.warn("dumps captured:  %d", len(usageList))
    log.warn("throttle events: %d", throttleEventCount)
    log.warn("fatal events:    %d", fatalErrorCount)
    log.warn("=====================================")
}

// 任意 fast-fail 触发: 立即非零退出, 让 CI / 调用方明确感知到测试被中断
// (报告已落盘, 可正常分析). 关键词: cachebench fast-fail exit code
if throttleTriggered {
    die(sprintf("aborted: upstream throttle x%d (limit=%d)", throttleEventCount, maxThrottleEvents))
}
if fatalErrorTriggered {
    die(sprintf("aborted: fatal error event detected (count=%d)", fatalErrorCount))
}
if stallTriggered {
    die(sprintf("aborted: no usage callback for >= %ds (stall)", stallTimeout))
}

// 与上游真实命中口径双口径都太低时退出码非 0, 便于 CI 卡线
// 需要至少 30 个样本才判, 否则冷启动 (前几次 chat) 必然命中率 0% 直接 die,
// 测量结果就丢了. 30 是经验阈值: 真实 hostscan 一般 40-130 prompt, 30 之前
// 主要是前几个 forge 的 cold start, 数据无代表性.
// 关键词: cachebench die threshold, 冷启动样本豁免
summary = benchReport["summary"]
if summary["totalCalls"] >= 30 {
    if summary["hitRatioTokenReal"] < 0.05 && summary["hitRatioLcpClient"] < 0.05 {
        log.warn("both hit ratios below 5%%, exiting with code 1")
        die("cache hit ratio below threshold")
    }
}

if err != nil && !maxPromptsTriggered && !maxDurationTriggered {
    die(sprintf("aim.InvokeReAct failed: %v", err))
}
