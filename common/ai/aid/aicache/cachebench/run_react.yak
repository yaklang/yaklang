// aicache cache hit benchmark - run_react.yak
//
// 用 aim.InvokeReAct 真实驱动一次 ReAct 闭环, 同时通过 ai.usageCallback
// 抓上游 LLM 在 SSE 末帧返回的 token 用量 (含 cached_tokens / cache_creation_input_tokens),
// 配合 aicache 自动落盘的 dump 文件, 输出"客户端 LCP 命中" + "上游真实命中"双路对齐报告。
//
// 默认 input 为 "hostscan", 与 plan 中的目标命令一致:
//   go run common/yak/cmd/yak.go -c 'aim.InvokeReAct("hostscan", aim.onEvent(...), aim.yoloMode())~'
//
// 用法 (必须从 yaklang 仓库根目录运行, 因为 include 走 cwd 相对路径):
//   cd /path/to/yaklang
//   go run common/yak/cmd/yak.go \
//       common/ai/aid/aicache/cachebench/run_react.yak \
//       --input hostscan --ai-type aibalance --max-iteration 15
//
// 关键词: aicache cachebench, run_react, usageCallback, dump alignment

// include 路径相对当前工作目录 (yak 编译器行为), 因此约定必须从仓库根目录调用。
include "common/ai/aid/aicache/cachebench/lib.yak"

// =============================================================================
// 启用 aicache dump 落盘
// 关键词: cachebench enable dump, YAKLANGDEBUG
// =============================================================================
// aicache.dumpDebug 仅在 utils.InDebugMode() 触发, 这里强制打开 YAKLANGDEBUG。
// 必须在调用 aim.InvokeReAct 之前设置, 否则首条 prompt 不会落盘。
os.Setenv("YAKLANGDEBUG", "1")

// =============================================================================
// CLI 参数
// =============================================================================
inputText  = cli.String("input", cli.setDefault("hostscan"),
    cli.setHelp("传给 aim.InvokeReAct 的初始 user input, 默认 hostscan"))
aiType     = cli.String("ai-type", cli.setDefault("aibalance"),
    cli.setHelp("aim.aiConfig 的第一个参数, 选 aispec 注册的 provider 名 (aibalance/openai/...)"))
aiModel    = cli.String("ai-model", cli.setDefault(""),
    cli.setHelp("可选, 强制覆盖 chater 默认 model (aibalance 多模型路由建议留空)"))
timeoutSec = cli.Int("timeout", cli.setDefault(60*20),
    cli.setHelp("aim.InvokeReAct 与单次 LLM 调用超时, 默认 1200 秒"))
maxIter    = cli.Int("max-iteration", cli.setDefault(15),
    cli.setHelp("React 循环最大迭代次数"))
maxPrompts = cli.Int("max-prompts", cli.setDefault(0),
    cli.setHelp("收集到 N 次 LLM prompt usage 后立即 cancel context 提前退出 (0 = 不限制)"))
language   = cli.String("language", cli.setDefault("zh"),
    cli.setHelp("传给 aim.language 的语言, 默认中文"))
outputDir  = cli.String("output-dir",
    cli.setDefault("./common/ai/aid/aicache/cachebench/reports"),
    cli.setHelp("报告产物根目录, 内部会自动建立 bottleneck-prompts 子目录"))
cli.check()

log.info("aicache cachebench - input=%s ai-type=%s max-iteration=%d max-prompts=%d", inputText, aiType, maxIter, maxPrompts)

// =============================================================================
// 取消上下文 (用于 max-prompts 限流)
// =============================================================================
// 当 maxPrompts > 0, 在 captureUsage 第 N 次回调时 cancel 这个 ctx;
// aim.InvokeReAct 收到 ctx.Done() 会停掉 React loop 并返回 context canceled.
// 关键词: cachebench max-prompts, ctx cancel
benchCtx, benchCancel = context.WithCancel(context.Background())
defer benchCancel()
maxPromptsTriggered = false

// =============================================================================
// usage 收集器
// =============================================================================
// aim.aiConfig 把 ai.usageCallback 透传到 aispec.ChatBase, 在 SSE 末帧解析后调用。
// React loop 里 chat 是顺序执行的, 因此这里按调用次序累加, 与 aicache 落盘的
// 000XXX.txt 文件序号一一对应。
//
// 关键词: cachebench usageCallback, 顺序对齐
usageMu     = sync.NewMutex()
usageList   = []
usageCount  = 0
firstUsage  = nil

func captureUsage(usage) {
    usageMu.Lock()
    defer usageMu.Unlock()
    usageCount++
    if usage == nil {
        // 区分两种 nil callback:
        //   1) max-prompts 触发后到达的 nil = 测量伪影 (ctx cancel 中断 SSE 末帧),
        //      不计入 missing 链路诊断
        //   2) max-prompts 触发前的 nil = 真实"上游没回 usage 或 callback 链路漏接",
        //      需要 P1-D 类继续排查
        // 关键词: captureUsage in_flight_cancelled, missing usage 测量伪影
        cancelled = maxPromptsTriggered
        record = {
            "seq":     usageCount,
            "missing": !cancelled,
            "inFlightCancelled": cancelled,
            "ts":      time.Now().Unix(),
        }
        usageList = append(usageList, record)
        if cancelled {
            log.info("usage callback nil after max-prompts cancel (in-flight, expected): seq=%d", usageCount)
        } else {
            log.warn("usage callback fired with nil (provider did not return usage block): seq=%d", usageCount)
        }
        return
    }

    cached    = 0
    creation  = 0
    cacheType = ""
    textTok   = 0
    if usage.PromptTokensDetails != nil {
        cached    = usage.PromptTokensDetails.CachedTokens
        creation  = usage.PromptTokensDetails.CacheCreationInputTokens
        cacheType = usage.PromptTokensDetails.CacheType
        textTok   = usage.PromptTokensDetails.TextTokens
    }

    record = {
        "seq":              usageCount,
        "missing":          false,
        "promptTokens":     usage.PromptTokens,
        "completionTokens": usage.CompletionTokens,
        "totalTokens":      usage.TotalTokens,
        "cachedTokens":     cached,
        "cacheCreation":    creation,
        "cacheType":        cacheType,
        "textTokens":       textTok,
        "ts":               time.Now().Unix(),
    }
    usageList = append(usageList, record)

    if firstUsage == nil {
        firstUsage = record
        log.info("first usage callback received: prompt=%d cached=%d creation=%d", usage.PromptTokens, cached, creation)
    }

    // 限流: 收满 maxPrompts 次就 cancel context, 让 aim.InvokeReAct 优雅停止
    // 关键词: cachebench max-prompts trigger
    if maxPrompts > 0 && usageCount >= maxPrompts && !maxPromptsTriggered {
        maxPromptsTriggered = true
        log.info("max-prompts(%d) reached, cancelling context to stop React loop", maxPrompts)
        benchCancel()
    }
}

// =============================================================================
// 事件采集 (节流, 不阻塞)
// =============================================================================
events = []
maxEventsKept = 200

func captureEvent(react, event) {
    if len(events) >= maxEventsKept {
        return
    }
    eventType = string(event.Type)
    contentText = string(event.Content)
    events = append(events, {
        "type":           eventType,
        "ts":             time.Now().Unix(),
        "contentPreview": ccbTruncate(contentText, 200),
    })
}

// =============================================================================
// 触发 aim.InvokeReAct
// =============================================================================
aiOpts = [ai.usageCallback(captureUsage), ai.timeout(timeoutSec)]
if aiModel != "" {
    aiOpts = append(aiOpts, ai.model(aiModel))
}

invokeStart = time.Now()
log.info("invoking aim.InvokeReAct, dump dir will be: %s", ai.aicacheSession())

err = aim.InvokeReAct(
    inputText,
    aim.context(benchCtx),
    aim.aiConfig(aiType, aiOpts...),
    aim.timeout(timeoutSec),
    aim.maxIteration(maxIter),
    aim.language(language),
    aim.yoloMode(),
    aim.allowUserInteract(false),
    aim.onEvent(captureEvent),
)

invokeEnd = time.Now()
durationSec = invokeEnd.Unix() - invokeStart.Unix()

if err != nil {
    if maxPromptsTriggered {
        log.info("aim.InvokeReAct stopped by max-prompts after %d seconds (expected): %v", durationSec, err)
    } else {
        log.warn("aim.InvokeReAct returned error: %v", err)
    }
} else {
    log.info("aim.InvokeReAct completed in %d seconds", durationSec)
}

// =============================================================================
// 等待末帧到达, 避免 ReAct loop 自然结束时 last-iteration chat 的 SSE 末帧
// (token usage block) 还没到达就开始对齐, 导致最后 1-2 条 dump 被误判 missing.
// 关键词: cachebench tail_in_flight, SSE 末帧等待
// =============================================================================
prevUsageCount = -1
stableMs = 0
maxWaitMs = 3000
stepMs = 200
for stableMs < 1500 && maxWaitMs > 0 {
    time.sleep(stepMs / 1000.0)
    maxWaitMs -= stepMs
    cur = len(usageList)
    if cur == prevUsageCount {
        stableMs += stepMs
    } else {
        stableMs = 0
        prevUsageCount = cur
    }
}
log.info("post-react drain done, final usage count = %d", len(usageList))

// =============================================================================
// 拉取 aicache dump 目录, 做对齐分析
// =============================================================================
sessionDir = ai.aicacheSession()
log.info("analyzing dumps in: %s", sessionDir)
log.info("usage callbacks captured: %d", len(usageList))

benchReport = analyzeBenchmark(sessionDir, usageList, events, err, inputText, maxPromptsTriggered)
benchReport["durationSec"] = durationSec
benchReport["aiType"] = aiType
benchReport["aiModel"] = aiModel
benchReport["maxIteration"] = maxIter
benchReport["maxPrompts"] = maxPrompts
benchReport["maxPromptsTriggered"] = maxPromptsTriggered

jsonPath, mdPath, botDir = saveReport(outputDir, benchReport)

log.info("benchmark report saved:")
log.info("  json:               %s", jsonPath)
log.info("  markdown:           %s", mdPath)
log.info("  bottleneck-prompts: %s", botDir)

printSummary(benchReport)

// 与上游真实命中口径双口径都太低时退出码非 0, 便于 CI 卡线
// 需要至少 30 个样本才判, 否则冷启动 (前几次 chat) 必然命中率 0% 直接 die,
// 测量结果就丢了. 30 是经验阈值: 真实 hostscan 一般 40-130 prompt, 30 之前
// 主要是前几个 forge 的 cold start, 数据无代表性.
// 关键词: cachebench die threshold, 冷启动样本豁免
summary = benchReport["summary"]
if summary["totalCalls"] >= 30 {
    if summary["hitRatioTokenReal"] < 0.05 && summary["hitRatioLcpClient"] < 0.05 {
        log.warn("both hit ratios below 5%%, exiting with code 1")
        die("cache hit ratio below threshold")
    }
}

if err != nil && !maxPromptsTriggered {
    die(sprintf("aim.InvokeReAct failed: %v", err))
}
