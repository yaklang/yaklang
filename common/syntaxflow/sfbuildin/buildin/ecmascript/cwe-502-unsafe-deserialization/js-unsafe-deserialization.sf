// Embedded test cases
// =====================================================================

// Test 1: HIGH — jsyaml.load() with direct req.params
desc(
	lang: "js"
	alert_high: 1
	'file:///unsafe_jsyaml_load_param.js': <<<CODE
const app = require("express")(),
      jsyaml = require("js-yaml");

app.get("load", function(req, res) {
    let data = jsyaml.load(req.params.data);
    res.json({ result: data });
});
CODE
)

// Test 2: HIGH — jsyaml.loadAll() with req.body
desc(
	lang: "js"
	alert_high: 1
	'file:///unsafe_jsyaml_loadall.js': <<<CODE
const express = require("express");
const jsyaml = require("js-yaml");
const app = express();
app.use(express.json());

app.post("/loadall", (req, res) => {
    const docs = jsyaml.loadAll(req.body.content);
    res.json({ docs });
});
CODE
)

// Test 3: HIGH — node-serialize.unserialize() with direct req.body
desc(
	lang: "js"
	alert_high: 1
	'file:///unsafe_node_serialize.js': <<<CODE
const express = require("express");
const serialize = require("node-serialize");
const app = express();
app.use(express.json());

app.post("/restore", (req, res) => {
    // BAD: IIFE payload can execute arbitrary code
    const obj = serialize.unserialize(req.body.data);
    res.json(obj);
});
CODE
)

// Test 4: HIGH — funcster.deepDeserialize() with req.body
desc(
	lang: "js"
	alert_high: 1
	'file:///unsafe_funcster.js': <<<CODE
const express = require("express");
const funcster = require("funcster");
const app = express();
app.use(express.json());

app.post("/deserialize", (req, res) => {
    const result = funcster.deepDeserialize(req.body.payload);
    res.json({ result });
});
CODE
)

// Test 5: SAFE — jsyaml.safeLoad() (v3.x safe API)
desc(
	lang: "js"
	alert_min: 0
	'safefile:///safe_jsyaml_safeload.js': <<<CODE
const app = require("express")(),
      jsyaml = require("js-yaml");

app.get("load", function(req, res) {
    // GOOD: safeLoad() only supports basic YAML types, no JS functions
    let data = jsyaml.safeLoad(req.params.data);
    res.json({ result: data });
});
CODE
)

// Test 6: SAFE — jsyaml.load() without user input (static YAML string)
desc(
	lang: "js"
	alert_min: 0
	'safefile:///safe_jsyaml_static.js': <<<CODE
const jsyaml = require("js-yaml");

// GOOD: loading a hard-coded config string — no user input
const config = jsyaml.load(`
server:
  host: localhost
  port: 8080
`);
console.log(config);
CODE
)
