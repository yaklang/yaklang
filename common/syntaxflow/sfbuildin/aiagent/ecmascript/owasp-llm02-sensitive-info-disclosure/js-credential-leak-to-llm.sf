desc(
	title: "AI Agent Sensitive Information Disclosure to LLM (JS/TS)"
	title_zh: "AI Agent 敏感信息泄露给 LLM（JS/TS）"
	type: vuln
	level: middle
	risk: "凭据泄露给 LLM"
	desc: <<<DESC
检测 JS/TS 中凭据在未经脱敏的情况下流入 LLM 的 prompt/messages（OWASP LLM02:2025）。
DESC
	solution: <<<SOLUTION
1. 对传入 LLM 的内容做凭据脱敏
2. 不要将完整 process.env 传给 LLM
SOLUTION
	reference: <<<REFERENCE
[OWASP LLM02:2025 Sensitive Information Disclosure](https://genai.owasp.org/llm-top-10/)
REFERENCE
	rule_id: "a1000001-0002-0002-0001-000000000010"
)

<include("aiagent-js-credential-access")> as $cred
<include("aiagent-js-llm-sources")> as $llm

$llm(* #{until: `* & $cred`}->) as $high

alert $high for {
	title: "AI Agent Credential Leak to LLM (JS/TS)"
	title_zh: "AI Agent 凭据泄露给 LLM（JS/TS）"
	level: "middle"
	type: "vuln"
	risk: "凭据值可能通过 LLM 回复泄露。"
	message: "检测到凭据访问结果流入 LLM API 调用。"
	name: "sink"
}

desc(
	lang: "js"
	alert_middle: 1
	'file://cred_leak.js': <<<UNSAFE
import OpenAI from "openai";
const client = new OpenAI();
async function leaky() {
    const key = process.env.SECRET_API_KEY;
    const r = await client.chat.completions.create({ model: "gpt-4", messages: [{ role: "system", content: `Use: ${key}` }] });
    return r.choices[0].message.content;
}
UNSAFE
	'safefile://safe_cred.js': <<<SAFE
import OpenAI from "openai";
const client = new OpenAI();
async function safe() {
    const r = await client.chat.completions.create({ model: "gpt-4", messages: [{ role: "user", content: "Hi" }] });
    return r.choices[0].message.content;
}
SAFE
)
