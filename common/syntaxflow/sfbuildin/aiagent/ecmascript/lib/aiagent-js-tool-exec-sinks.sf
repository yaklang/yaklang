desc(
	title: "AI Agent tool execution sinks (JS/TS lib)"
	title_zh: "AI Agent 工具执行入口（JS/TS 库规则）"
	type: audit
	level: info
	lib: "aiagent-js-tool-exec-sinks"
	risk: "AI Agent 工具执行"
	desc: <<<DESC
标记 JS/TS AI Agent 中所有可能执行外部操作的工具调用入口：child_process 命令执行、eval/Function/vm 代码执行。
注意：本规则只标注 sink 位置，不单独报警。需要配合 aiagent-js-llm-sources 做数据流分析。
DESC
	solution: <<<SOLUTION
对 LLM 返回的 tool_calls 参数做严格白名单校验；使用沙箱隔离代码执行。
SOLUTION
	reference: <<<REFERENCE
[OWASP LLM05:2025 Improper Output Handling](https://genai.owasp.org/llm-top-10/)
REFERENCE
	rule_id: "a1000001-0001-0001-0001-000000000011"
)

// child_process execution
exec as $output
execSync as $output
spawn as $output
spawnSync as $output

// Code execution
eval as $output
new Function as $output
vm.runInNewContext as $output
vm.runInContext as $output
vm.runInThisContext as $output

alert $output for {
	title: "AI Agent tool execution sink (JS/TS)"
	title_zh: "AI Agent 工具执行入口（JS/TS）"
	level: "info"
	type: "audit"
	risk: "AI Agent 工具执行"
	message: "识别到可被 tool_calls 利用的执行入口。"
	name: "output"
}

desc(
	lang: "js"
	alert_min: 0
	'file://agent_exec.js': <<<UNSAFE
import { exec } from "child_process";
function runTool(command) {
    exec(command, (err, stdout) => {});
}
UNSAFE
	'safefile://safe_agent.js': <<<SAFE
function safe() { return 1 + 1; }
SAFE
)
