desc(
	title: "AI Agent credential access patterns (JS/TS lib)"
	title_zh: "AI Agent 凭据访问模式（JS/TS 库规则）"
	type: audit
	level: info
	lib: "aiagent-js-credential-access"
	risk: "AI Agent 凭据泄露"
	desc: <<<DESC
标记 JS/TS AI Agent 中访问特定凭据环境变量的模式。
注意：本规则只标注 source 位置，不单独报警。需要配合 aiagent-js-llm-sources 做数据流分析。
DESC
	solution: <<<SOLUTION
使用密钥管理服务；对 tool result 做脱敏。
SOLUTION
	reference: <<<REFERENCE
[OWASP LLM02:2025 Sensitive Information Disclosure](https://genai.owasp.org/llm-top-10/)
REFERENCE
	rule_id: "a1000001-0001-0001-0001-000000000012"
)

// 只检测明确的凭据环境变量名访问
process.env.OPENAI_API_KEY as $output
process.env.ANTHROPIC_API_KEY as $output
process.env.API_KEY as $output
process.env.SECRET_KEY as $output
process.env.TOKEN as $output
process.env.AWS_SECRET_ACCESS_KEY as $output
process.env.GITHUB_TOKEN as $output
process.env.DATABASE_URL as $output
process.env.SECRET as $output

alert $output for {
	title: "AI Agent credential access (JS/TS)"
	title_zh: "AI Agent 凭据访问（JS/TS）"
	level: "info"
	type: "audit"
	risk: "AI Agent 凭据泄露"
	message: "识别到凭据访问模式，请确保凭据值不会通过 tool result 泄露给 LLM。"
	name: "output"
}

desc(
	lang: "js"
	alert_min: 0
	'file://cred_access.js': <<<UNSAFE
const apiKey = process.env.OPENAI_API_KEY;
const token = process.env.ANTHROPIC_API_KEY;
UNSAFE
	'safefile://safe_cred.js': <<<SAFE
function safe() { return 1 + 1; }
SAFE
)
