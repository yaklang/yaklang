desc(
	title: "AI Agent Model DoS: Unbounded Input to LLM (JS/TS)"
	title_zh: "AI Agent 模型 DoS：无限制输入传入 LLM（JS/TS）"
	type: vuln
	level: middle
	risk: "模型拒绝服务"
	desc: <<<DESC
检测用户可控输入在未限制长度的情况下直接传入 LLM（JS/TS）。攻击者可发送超长输入消耗大量 token（OWASP LLM04）。
DESC
	solution: <<<SOLUTION
1. 对传入 LLM 的输入做长度限制
2. 设置 Agent 最大迭代轮次
3. 设置 token budget 和超时
4. 实施 rate limiting
SOLUTION
	reference: <<<REFERENCE
[OWASP LLM04:2023 Model DoS](https://owasp.org/www-project-top-10-for-large-language-model-applications/)
[CWE-400: Uncontrolled Resource Consumption](https://cwe.mitre.org/data/definitions/400.html)
REFERENCE
	rule_id: "a1000001-0002-0004-0001-000000000010"
)

<include("js-param")> as $input
<include("aiagent-js-llm-sources")> as $llm

$llm(* #{until: `* & $input`}->) as $medium

alert $medium for {
	title: "AI Agent Model DoS: Unbounded Input (JS/TS)",
	title_zh: "AI Agent 模型 DoS：无限制输入（JS/TS）",
	level: "middle",
	type: "vuln",
	risk: "未限制长度的用户输入传入 LLM，可能导致资源耗尽。",
	message: "检测到未限制的用户输入流入 LLM，可能导致 DoS。",
	name: "sink",
}

desc(
	lang: "js"
	alert_middle: 1
	'file://dos_agent.js': <<<UNSAFE
import OpenAI from "openai";
import express from "express";
const client = new OpenAI();
const app = express();
app.get("/chat", async (req, res) => {
    const response = await client.chat.completions.create({ model: "gpt-4", messages: [{ role: "user", content: req.query.q }] });
    res.send(response.choices[0].message.content);
});
UNSAFE
	'safefile://safe_dos.js': <<<SAFE
import OpenAI from "openai";
const client = new OpenAI();
async function safe() {
    const r = await client.chat.completions.create({ model: "gpt-4", messages: [{ role: "user", content: "Hi" }] });
    return r.choices[0].message.content;
}
SAFE
)
