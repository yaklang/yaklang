desc(
	title: "AI Agent Sensitive Information Disclosure to LLM"
	title_zh: "AI Agent 敏感信息泄露给 LLM"
	type: vuln
	level: middle
	risk: "凭据泄露给 LLM"
	desc: <<<DESC
检测 API Key、Token 等凭据在未经脱敏的情况下流入 LLM 的 prompt/messages。
当 Agent 读取环境变量中的凭据后将其作为上下文传给 LLM，或 tool result 中包含凭据字符串时，
LLM 可能在后续回复中泄露这些信息（OWASP LLM02:2025）。
DESC
	solution: <<<SOLUTION
1. 对所有传入 LLM 的内容做凭据脱敏
2. 不要将完整环境变量传给 LLM
3. 对 tool result 做过滤
SOLUTION
	reference: <<<REFERENCE
[OWASP LLM02:2025 Sensitive Information Disclosure](https://genai.owasp.org/llm-top-10/)
[CWE-200: Information Exposure](https://cwe.mitre.org/data/definitions/200.html)
REFERENCE
	rule_id: "a1000001-0002-0002-0001-000000000001"
)

<include("aiagent-credential-access")> as $cred
<include("aiagent-llm-sources")> as $llm

$llm(* #{until: `* & $cred`}->) as $high

alert $high for {
	title: "AI Agent Credential Leak to LLM"
	title_zh: "AI Agent 凭据泄露给 LLM"
	level: "middle"
	type: "vuln"
	risk: "凭据值可能通过 LLM 回复泄露给用户或攻击者。"
	message: "检测到凭据访问结果流入 LLM API 调用，可能导致敏感信息泄露。"
	name: "sink"
}

desc(
	lang: python
	alert_middle: 1
	'file://cred_leak.py': <<<UNSAFE
import os
from openai import OpenAI

client = OpenAI()

def leaky_agent():
    api_key = os.getenv("SECRET_API_KEY")
    response = client.chat.completions.create(
        model="gpt-4",
        messages=[{"role": "system", "content": f"Use this key: {api_key}"}]
    )
    return response.choices[0].message.content
UNSAFE
	'safefile://safe_cred.py': <<<SAFE
import os
from openai import OpenAI

client = OpenAI(api_key=os.getenv("OPENAI_API_KEY"))

def safe_agent():
    response = client.chat.completions.create(
        model="gpt-4",
        messages=[{"role": "user", "content": "What is 1+1?"}]
    )
    return response.choices[0].message.content
SAFE
)
