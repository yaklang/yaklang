desc(
	title: "AI Agent credential access patterns (Python lib)"
	title_zh: "AI Agent 凭据访问模式（Python 库规则）"
	type: audit
	level: info
	lib: "aiagent-credential-access"
	risk: "AI Agent 凭据泄露"
	desc: <<<DESC
标记 AI Agent 代码中访问 API Key、Token、Secret 等凭据的模式。
包括 os.getenv 访问敏感环境变量名（OPENAI_API_KEY、ANTHROPIC_API_KEY 等）。
注意：本规则只标注 source 位置，不单独报警。需要配合 aiagent-llm-sources 做数据流分析。
DESC
	solution: <<<SOLUTION
使用密钥管理服务；对 tool result 做脱敏；不要将凭据值回传给 LLM。
SOLUTION
	reference: <<<REFERENCE
[OWASP LLM02:2025 Sensitive Information Disclosure](https://genai.owasp.org/llm-top-10/)
REFERENCE
	rule_id: "a1000001-0001-0001-0001-000000000003"
)

// 只检测明确的凭据环境变量名访问，不泛化到所有 os.getenv/os.environ
os.getenv("OPENAI_API_KEY") as $output
os.getenv("ANTHROPIC_API_KEY") as $output
os.getenv("API_KEY") as $output
os.getenv("SECRET_KEY") as $output
os.getenv("TOKEN") as $output
os.getenv("AWS_SECRET_ACCESS_KEY") as $output
os.getenv("GITHUB_TOKEN") as $output
os.getenv("DATABASE_URL") as $output
os.getenv("SECRET") as $output

alert $output for {
	title: "AI Agent credential access"
	title_zh: "AI Agent 凭据访问"
	level: "info"
	type: "audit"
	risk: "AI Agent 凭据泄露"
	message: "识别到凭据访问模式，请确保凭据值不会通过 tool result 泄露给 LLM。"
	name: "output"
}

desc(
	lang: python
	alert_min: 0
	'file://cred_access.py': <<<UNSAFE
import os
api_key = os.getenv("OPENAI_API_KEY")
token = os.getenv("ANTHROPIC_API_KEY")
UNSAFE
	'safefile://safe_cred.py': <<<SAFE
def safe_function():
    return 1 + 1
SAFE
)
