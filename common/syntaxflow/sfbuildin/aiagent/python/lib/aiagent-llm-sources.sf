desc(
	title: "AI Agent LLM API call sources (Python lib)"
	title_zh: "AI Agent LLM API 调用源（Python 库规则）"
	type: audit
	level: info
	lib: "aiagent-llm-sources"
	risk: "AI Agent LLM 调用"
	desc: <<<DESC
标记所有主流 LLM SDK 的 API 调用入口。这是 AI Agent 的核心功能——调用 LLM 是正常行为，
本规则只做信息标注，不做漏洞报警。供其他规则通过 include 做数据流分析使用。
DESC
	solution: <<<SOLUTION
此规则为 lib 库规则，不直接报告漏洞。标注 LLM 调用位置供审计参考。
SOLUTION
	reference: <<<REFERENCE
[OWASP LLM01:2025 Prompt Injection](https://genai.owasp.org/llm-top-10/)
REFERENCE
	rule_id: "a1000001-0001-0001-0001-000000000001"
)

// OpenAI SDK
client.chat.completions.create as $output
*.chat.completions.create as $output
client.responses.create as $output
*.responses.create as $output
client.embeddings.create as $output
*.embeddings.create as $output

// Anthropic SDK
client.messages.create as $output
*.messages.create as $output
client.messages.stream as $output
*.messages.stream as $output

// LangChain
ChatOpenAI as $output
ChatAnthropic as $output
llm.invoke as $output
llm.ainvoke as $output
chain.invoke as $output
chain.ainvoke as $output
agent.invoke as $output
agent.ainvoke as $output
agent_executor.invoke as $output
agent_executor.ainvoke as $output
AgentExecutor as $output

// LlamaIndex
llm.complete as $output
llm.acomplete as $output
llm.chat as $output
llm.achat as $output

alert $output for {
	title: "AI Agent LLM API call"
	title_zh: "AI Agent LLM API 调用"
	level: "info"
	type: "audit"
	risk: "AI Agent LLM 调用"
	message: "识别到 LLM API 调用入口，这是 Agent 的正常功能，标注位置供审计参考。"
	name: "output"
}

desc(
	lang: python
	alert_min: 1
	'file://openai_agent.py': <<<UNSAFE
from openai import OpenAI
client = OpenAI()
response = client.chat.completions.create(model="gpt-4", messages=[{"role": "user", "content": "hello"}])
UNSAFE
	'safefile://safe_llm.py': <<<SAFE
def safe_function():
    return 1 + 1
SAFE
)
