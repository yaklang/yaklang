{
  "BaseInfo": {
    "program_names": ["ci-yaklang-promote"],
    "language": "golang"
  },
  "CodeSource": {
    "kind": "local",
    "local_file": "./fs.zip"
  },
  "SSACompile": {
    "enable_incremental_compile": true,
    "base_program_name": "ci-yaklang-base",
    "memory_compile": false,
    "compile_concurrency": 4,
    "file_performance_log": true,
    "exclude_files": [
      "**/vendor/**",
      "vendor/**",
      "**/classes/**",
      "**/target/**",
      "**include/**",
      "**caches/**",
      "**cache/**",
      "**tmp/**",
      "**alipay/**",
      "**includes/**",
      "**temp/**",
      "**zh_cn/**",
      "**zh_en/**",
      "**plugins/**",
      "**PHPExcel/**",
      "**/tests/**",
      "**/test/**",
      "*.pb.go",
      "*_test.go",
      "**vulinbox/**"
    ]
  }
}
