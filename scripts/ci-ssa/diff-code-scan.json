{
  "BaseInfo": {
    "program_names": ["ci-yaklang-diff"],
    "language": "golang"
  },
  "CodeSource": {
    "kind": "local",
    "local_file": "./fs.zip"
  },
  "SSACompile": {
    "enable_incremental_compile": true,
    "base_program_name": "ci-yaklang-base",
    "memory_compile": false,
    "file_performance_log": true,
    "exclude_files": [
      "**/vendor/**",
      "vendor/**",
      "**/classes/**",
      "**/target/**",
      "**include/**",
      "**caches/**",
      "**cache/**",
      "**tmp/**",
      "**alipay/**",
      "**includes/**",
      "**temp/**",
      "**zh_cn/**",
      "**zh_en/**",
      "**plugins/**",
      "**PHPExcel/**",
      "**/tests/**",
      "**/test/**",
      "*.pb.go",
      "*_test.go",
      "**vulinbox/**"
    ]
  },
  "SyntaxFlow": {
    "memory": true
  },
  "SyntaxFlowRule": {
    "rule_filter": {
      "Keyword": "golang",
      "FilterLibRuleKind": "noLib"
    }
  },
  "Output": {
    "output_format": "irify-full",
    "output_file": "risk"
  }
}
