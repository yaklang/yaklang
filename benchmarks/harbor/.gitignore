# Generated by the benchmark harness — never commit.
# ai-config.yaml contains API credentials (see scripts/gen_ai_config_yaml.py).
ai-config.yaml

# Harbor job output and converted JSONL.
results/
*.jsonl

# Python bytecode.
__pycache__/
*.pyc

# Generated gRPC stubs for the local yak backend (run_local.py --backend grpc).
# Regenerate with: python3 -m grpc_tools.protoc -Icommon/yakgrpc \
#   --python_out=agents/_grpc_stubs --grpc_python_out=agents/_grpc_stubs \
#   common/yakgrpc/yakgrpc.proto
agents/_grpc_stubs/

# Task fixtures under datasets/ are part of the task spec and MUST be tracked,
# even though the root .gitignore has a broad `*.log` rule. Re-include them.
!datasets/**/incident.log

